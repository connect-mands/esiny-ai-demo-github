# Copy to `.env` for local development, or set these in your CI/hosting
# dashboard for production builds (`vite build` inlines VITE_* at build time).

# -----------------------------------------------------------------------------
# API — backend base URL (include path `/api/v1`, no trailing slash)
# -----------------------------------------------------------------------------
# Deployed backend (Snapphound tests):
VITE_BASE_URL=https://uks40k0cgks4ow4s4ogcsw4s.snapphoundtests.com/api/v1

# Local backend instead (matches `src/config/env.ts` fallback when this file is not used):
# VITE_BASE_URL=http://localhost:5000/api/v1

# -----------------------------------------------------------------------------
# Main site — ESINY marketing site origin for header/footer links (no trailing slash)
# -----------------------------------------------------------------------------
# Same app / relative routes only — leave empty or omit:
VITE_MAIN_URL=

# Production when this app is on a subdomain and links should go to the main site:
# VITE_MAIN_URL=https://www.yourdomain.com
